# Local GalaxeaFM environment.
# Keep this template free of real paths and secrets.
#
# Usage:
#   source .env

# Required: repository location.
export PROJECT_ROOT="__PATH_TO_G05_REPO__"

# Required for training: Hydra writes checkpoints and logs under this directory.
export G05_OUTPUT_DIR="__PATH_TO_OUTPUT_DIR__"

# Recommended: Hugging Face model/tokenizer/dataset caches.
export HF_HOME="__PATH_TO_HF_CACHE_ROOT__"
export HF_HUB_CACHE=$HF_HOME/hub
export HF_DATASETS_CACHE=$HF_HOME/datasets

# Recommended: package and torch caches.
export PIP_CACHE_DIR="__PATH_TO_PIP_CACHE__"
export TORCH_HOME="__PATH_TO_TORCH_CACHE__"

# Optional: use a Hugging Face mirror when direct access is slow or blocked.
# export HF_ENDPOINT="__HF_ENDPOINT__"

# Optional: required only for private/gated Hugging Face resources.
# export HF_TOKEN="__HF_TOKEN__"

# Optional: required only for LIBERO simulation evaluation.
# LIBERO reads/writes config.yaml in this directory to locate bddl/init/assets.
export LIBERO_CONFIG_PATH=$PROJECT_ROOT/experiments/libero

# Optional: required only when logger.type=swanlab.
# export SWANLAB_API_KEY="__SWANLAB_API_KEY__"

# Optional: required only when logger.type=wandb and logger.mode=online.
# export WANDB_API_KEY="__WANDB_API_KEY__"
# export WANDB_BASE_URL="__WANDB_BASE_URL__"

# Optional: uv mirrors for restricted network environments.
# export UV_DEFAULT_INDEX="__UV_PYPI_INDEX__"
# export UV_PYTHON_INSTALL_MIRROR="__UV_PYTHON_INSTALL_MIRROR__"

# Runtime defaults.
export PYTHONPATH=$PROJECT_ROOT:$PYTHONPATH
export TOKENIZERS_PARALLELISM=false
export HYDRA_FULL_ERROR=1
export MUJOCO_GL=egl
export LC_CTYPE=en_US.UTF-8

# Performance defaults for multi-process training.
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1
export CV_NUM_THREADS=1
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
